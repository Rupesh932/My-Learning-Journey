      "seed": 253389138,
      "version": 398,
      "versionNonce": 437567118,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776396950709,
      "link": null,
      "locked": false,
      "text": "first rem: 1 \n   ans =  1 * 10 ^ 0 + ans \n          =   1 + 0 => 1",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "first rem: 1 \n   ans =  1 * 10 ^ 0 + ans \n          =   1 + 0 => 1",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "qYQbkUFP8uHOeym2ruyuP",
      "type": "text",
      "x": 848,
      "y": 1554.1,
      "width": 163.71237182617188,
      "height": 64.80000000000001,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "b9K-MxWFUylEXLpf1yGEe",
        "6wYfmIOpnXS8yrjT-mbjs",
        "r3uxp5jcQpadJdyQpFP-9"
      ],
      "frameId": null,
      "index": "bB0",
      "roundness": null,
      "seed": 461295374,
      "version": 461,
      "versionNonce": 1046068430,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776396950709,
      "link": null,
      "locked": false,
      "text": "second rem: 0 \n   ans =  0 * 10 ^ 1 + 1 \n          =   0 + 1 => 1",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "second rem: 0 \n   ans =  0 * 10 ^ 1 + 1 \n          =   0 + 1 => 1",
      "autoResize": true,
      "lineHeight": 1.35
