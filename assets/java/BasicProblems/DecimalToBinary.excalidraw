      "link": null,
      "locked": false,
      "text": "int num = scanner.nextInt();\n  int rem , mul = 1, ans = 0;\n  while(num > 0){\n      rem = num % 2 ; \n      num = num / 2; \n      ans = rem * mul +ans;\n      mul = mul * 10;   \n   }\n  ",
      "fontSize": 22.432989690721648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int num = scanner.nextInt();\n  int rem , mul = 1, ans = 0;\n  while(num > 0){\n      rem = num % 2 ; \n      num = num / 2; \n      ans = rem * mul +ans;\n      mul = mul * 10;   \n   }\n  ",
      "autoResize": true,
      "lineHeight": 1.25
