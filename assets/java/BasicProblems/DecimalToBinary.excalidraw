      "updated": 1776396950709,
      "link": null,
      "locked": false,
      "text": "here we've 1 as first reminder but binary is in reverse order, apply \n conclusion 2 to get binary at reverse order in coding as we've \n   reminder as individual number.",
      "fontSize": 16.6394779771615,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "here we've 1 as first reminder but binary is in reverse order, apply \n conclusion 2 to get binary at reverse order in coding as we've \n   reminder as individual number.",
      "autoResize": true,
      "lineHeight": 1.35
    },
