    {
      "id": "mt4nRUKGZsGjEUssWlATm",
      "type": "text",
      "x": 430,
      "y": 1271,
      "width": 578.7213745117188,
      "height": 129.60000000000002,
      "angle": 0,
      "strokeColor": "#1971c2",
