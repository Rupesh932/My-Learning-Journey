      "isDeleted": false,
      "boundElements": null,
      "updated": 1775470758368,
      "link": null,
      "locked": false,
      "text": "our JVM has interpreter to translate bytecode into machine code and Just-in-Time (JIT) compiler\nalso translate bytecode into machine code for fast execution.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "our JVM has interpreter to translate bytecode into machine code and Just-in-Time (JIT) compiler\nalso translate bytecode into machine code for fast execution.",
