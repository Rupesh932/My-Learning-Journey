      "groupIds": [
        "GPefYSwDkoVbrR5iodehm",
        "67hdscsLD5Ne5IHIU4U2_"
      ],
      "frameId": null,
      "index": "b384",
      "roundness": null,
      "seed": 1742215153,
      "version": 191,
      "versionNonce": 1492147537,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775714220266,
      "link": null,
      "locked": false,
      "text": "कम्प्युटरले त मेमोरी एड्रेस हेरेर दुईटा कुरा एउटै हो कि होइन भन्ला, तर मान्छेको बुझाइमा 'Identity' (परिचय) र 'Location' (मेमोरीको ठेगाना) फरक कुरा हुन्।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "कम्प्युटरले त मेमोरी एड्रेस हेरेर दुईटा कुरा एउटै हो कि होइन भन्ला, तर मान्छेको बुझाइमा 'Identity' (परिचय) र 'Location' (मेमोरीको ठेगाना) फरक कुरा हुन्।",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "fqjRshObIAB6IsRniJfiv",
      "type": "text",
      "x": 61.99446105957031,
      "y": 3824.8999999999996,
      "width": 253.4565887451172,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#da77f2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "ypeYon-AY3FOrPcftaet2",
        "GPefYSwDkoVbrR5iodehm",
        "67hdscsLD5Ne5IHIU4U2_"
      ],
      "frameId": null,
      "index": "b388",
      "roundness": null,
      "seed": 423230641,
      "version": 155,
      "versionNonce": 852204607,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775714220266,
      "link": null,
      "locked": false,
      "text": "मानौँ, तिमीसँग दुइटा ५ रुपैयाँका सिक्का छन्।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "मानौँ, तिमीसँग दुइटा ५ रुपैयाँका सिक्का छन्।",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
