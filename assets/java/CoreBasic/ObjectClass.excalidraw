      "type": "text",
      "x": 52.99446105957031,
      "y": 3849.8999999999996,
      "width": 533.521240234375,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
