      "roundness": null,
      "seed": 30158751,
      "version": 194,
      "versionNonce": 1719307057,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775714220266,
      "link": null,
      "locked": false,
      "text": "    कम्प्युटरको नजरमा (==): ती दुईटा सिक्का फरक हुन्, किनभने ती दुईटा छुट्टाछुट्टै ठाउँमा छन्।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    कम्प्युटरको नजरमा (==): ती दुईटा सिक्का फरक हुन्, किनभने ती दुईटा छुट्टाछुट्टै ठाउँमा छन्।",
      "autoResize": true,
      "lineHeight": 1.35
    },
