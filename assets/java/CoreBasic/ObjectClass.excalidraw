      "updated": 1775715975942,
      "link": null,
      "locked": false,
      "text": "String s1 = new String(\"Rupesh\");\nString s2 = new String(\"Rupesh\");\n\ns1 == s2;      // False (मेमोरी ठेगाना फरक छ)\ns1.equals(s2); // True  (भित्रको अक्षर \"Rupesh\" एउटै छ)",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "String s1 = new String(\"Rupesh\");\nString s2 = new String(\"Rupesh\");\n\ns1 == s2;      // False (मेमोरी ठेगाना फरक छ)\ns1.equals(s2); // True  (भित्रको अक्षर \"Rupesh\" एउटै छ)",
      "autoResize": true,
      "lineHeight": 1.25
    },
