    {
      "id": "RXZ04soMndPbhHlgTSMEX",
      "type": "text",
      "x": -37,
      "y": 3665.7,
      "width": 915.3140869140625,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "A1A8-gMs0U98A_PPn6NYP"
      ],
      "frameId": null,
      "index": "b0A",
      "roundness": null,
      "seed": 160279557,
      "version": 740,
      "versionNonce": 553236127,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775713123586,
      "link": null,
      "locked": false,
      "text": "Object-oriented संसारमा अब्जेक्टहरूलाई दाँज्न एउटा Standard चाहिन्छ। त्यही Standard सेट गर्न Object Class मा Comparison Methods बनाइयो",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Object-oriented संसारमा अब्जेक्टहरूलाई दाँज्न एउटा Standard चाहिन्छ। त्यही Standard सेट गर्न Object Class मा Comparison Methods बनाइयो",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "valgK7jPZFoxBrjSoA-8T",
      "type": "text",
      "x": -36,
      "y": 3688,
      "width": 1063.234619140625,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#a18072",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "A1A8-gMs0U98A_PPn6NYP"
      ],
      "frameId": null,
      "index": "b0B",
      "roundness": null,
      "seed": 730983397,
      "version": 738,
      "versionNonce": 1301923537,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775713123586,
      "link": null,
      "locked": false,
      "text": "यदि जाभामा हरेक कुरा अब्जेक्ट हो भने, दुईवटा अब्जेक्टलाई एकअर्कासँग दाँज्ने एउटा ग्लोबल मेकानिजम हुनैपर्छ। यही सोचबाट Object क्लास भित्र दुईवटा 'Comparison' मेथड्स जन्मिए:",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "यदि जाभामा हरेक कुरा अब्जेक्ट हो भने, दुईवटा अब्जेक्टलाई एकअर्कासँग दाँज्ने एउटा ग्लोबल मेकानिजम हुनैपर्छ। यही सोचबाट Object क्लास भित्र दुईवटा 'Comparison' मेथड्स जन्मिए:",
      "autoResize": true,
      "lineHeight": 1.35
    },
