      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "NK8Ft-inSbeuXxeD9mAjG"
      ],
      "frameId": null,
      "index": "b1L",
      "roundness": null,
      "seed": 1111766033,
      "version": 234,
      "versionNonce": 1072076575,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775718553834,
      "link": null,
      "locked": false,
      "text": "The Invisible Call (Implicit toString)\n    \"जब हामी एउटा Object लाई String को रुपमा प्रयोग गर्छौँ, Java ले आफैँ .toString() खोज्छ।\"\n    Scenario 1: sout(obj) ⮕ obj.toString()\n    Scenario 2: \"Data: \" + obj ⮕ \"Data: \" + obj.toString()\n    Scenario 3: String.valueOf(obj) ⮕ obj.toString()",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The Invisible Call (Implicit toString)\n    \"जब हामी एउटा Object लाई String को रुपमा प्रयोग गर्छौँ, Java ले आफैँ .toString() खोज्छ।\"\n    Scenario 1: sout(obj) ⮕ obj.toString()\n    Scenario 2: \"Data: \" + obj ⮕ \"Data: \" + obj.toString()\n    Scenario 3: String.valueOf(obj) ⮕ obj.toString()",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
