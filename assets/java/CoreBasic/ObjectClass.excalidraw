    {
      "id": "UBykgb24DeWUgLC09ZQkS",
      "type": "text",
      "x": 90.99446105957031,
      "y": 2778.9,
      "width": 656.241455078125,
      "height": 280,
      "angle": 0,
      "strokeColor": "#4dabf7",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "auU3dMGaf3-iJN1Y39pCX"
      ],
      "frameId": null,
      "index": "b1O",
      "roundness": null,
      "seed": 390105151,
      "version": 197,
      "versionNonce": 1497996465,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775718544694,
      "link": null,
      "locked": false,
      "text": "१. System.out.println() को भित्री मेकानिजम\n\nजब तिमी System.out.println(obj) लेख्छौ, जाभाको PrintStream क्लासले भित्र यस्तो लजिक चलाउँछ:\n\npublic void println(Object x) {\n    String s = String.valueOf(x); // यहाँ String.valueOf() कल हुन्छ\n    // ... बाँकी प्रिन्ट गर्ने कोड\n}\n\nअनि त्यो String.valueOf(x) ले फेरि भित्र यस्तो गर्छ:\n\npublic static String valueOf(Object obj) {\n    return (obj == null) ? \"null\" : obj.toString(); // यहाँ toString() कल भयो!\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "१. System.out.println() को भित्री मेकानिजम\n\nजब तिमी System.out.println(obj) लेख्छौ, जाभाको PrintStream क्लासले भित्र यस्तो लजिक चलाउँछ:\n\npublic void println(Object x) {\n    String s = String.valueOf(x); // यहाँ String.valueOf() कल हुन्छ\n    // ... बाँकी प्रिन्ट गर्ने कोड\n}\n\nअनि त्यो String.valueOf(x) ले फेरि भित्र यस्तो गर्छ:\n\npublic static String valueOf(Object obj) {\n    return (obj == null) ? \"null\" : obj.toString(); // यहाँ toString() कल भयो!\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
