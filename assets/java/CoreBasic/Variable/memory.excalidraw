      "roundness": null,
      "seed": 1491626747,
      "version": 432,
      "versionNonce": 186593749,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776055626870,
      "link": null,
      "locked": false,
      "text": "exponent lai 8-bit dekox, so max numer can be represent  2 ^ 8 -1 = 255\n   bias = 2 ^ (range of exp -1)   - 1 = 2 ^ (8 -1) -1 = 128 - 1 = 127.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "exponent lai 8-bit dekox, so max numer can be represent  2 ^ 8 -1 = 255\n   bias = 2 ^ (range of exp -1)   - 1 = 2 ^ (8 -1) -1 = 128 - 1 = 127.",
      "autoResize": true,
      "lineHeight": 1.35
    },
