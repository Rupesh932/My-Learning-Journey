    {
      "id": "gV_BqRL0L7EHilzF7k-F5",
      "type": "text",
      "x": 360.83095542830654,
      "y": 3760.3155139765813,
      "width": 523.7772827148438,
      "height": 43.2,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
