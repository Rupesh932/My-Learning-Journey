    {
      "id": "iKoMylXKgaNdpqfXOXfoE",
      "type": "text",
      "x": 310,
      "y": 3988,
      "width": 685.5535278320312,
      "height": 43.2,
      "angle": 0,
      "strokeColor": "#099268",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "Mv7XDDkLn_yhix5bee4_P",
        "tVqWdFfxbRqHys2fMPA6j"
      ],
      "frameId": null,
      "index": "b2O",
      "roundness": null,
      "seed": 1807973191,
      "version": 110,
      "versionNonce": 1491790535,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775974543745,
      "link": null,
      "locked": false,
      "text": "Size: यो अलि अनौठो छ। जाभाको भर्चुअल मेसिन (JVM) मा एउटा एक्लो boolean भेरिएबलले १-बाइट ओगट्न सक्छ, \n                तर boolean एरे (Array) मा यो १-बिट मा पनि खुम्चिन सक्छ। (यो JVM मा भर पर्छ)।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Size: यो अलि अनौठो छ। जाभाको भर्चुअल मेसिन (JVM) मा एउटा एक्लो boolean भेरिएबलले १-बाइट ओगट्न सक्छ, \n                तर boolean एरे (Array) मा यो १-बिट मा पनि खुम्चिन सक्छ। (यो JVM मा भर पर्छ)।",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "ETRoACgq7k2Vai7FSZPTp",
      "type": "text",
      "x": 310,
      "y": 4051,
      "width": 579.3614501953125,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "Mv7XDDkLn_yhix5bee4_P",
        "tVqWdFfxbRqHys2fMPA6j"
      ],
      "frameId": null,
      "index": "b2P",
      "roundness": null,
      "seed": 1752283527,
      "version": 105,
      "versionNonce": 99613159,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775974543745,
      "link": null,
      "locked": false,
      "text": "    Values: यसमा मात्र दुईवटा कुरा हुन्छ— true र false। (C प्रोग्रामिङमा जस्तो ० वा १ यहाँ चल्दैन)।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    Values: यसमा मात्र दुईवटा कुरा हुन्छ— true र false। (C प्रोग्रामिङमा जस्तो ० वा १ यहाँ चल्दैन)।",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "pCWdZE71YSLgffBeJ_-fk",
      "type": "text",
      "x": 310,
      "y": 4087,
      "width": 400.6248779296875,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
