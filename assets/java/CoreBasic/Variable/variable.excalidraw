      "isDeleted": false,
      "boundElements": [],
      "updated": 1775971679264,
      "link": null,
      "locked": false,
      "text": "इन्कोडिङ भनेको साधारण भाषामा— \"मान्छेले बुझ्ने अक्षरलाई कम्प्युटरले बुझ्ने 0 र 1 मा बदल्ने रुलबुक\" हो।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "इन्कोडिङ भनेको साधारण भाषामा— \"मान्छेले बुझ्ने अक्षरलाई कम्प्युटरले बुझ्ने 0 र 1 मा बदल्ने रुलबुक\" हो।",
      "autoResize": true,
      "lineHeight": 1.35
    },
