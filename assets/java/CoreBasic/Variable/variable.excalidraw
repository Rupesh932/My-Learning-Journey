    {
      "id": "KzYbtPKyG9KnyiZS7x8eU",
      "type": "text",
      "x": 336,
      "y": 2188,
      "width": 652.2575073242188,
      "height": 108,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "buJqE1iLCjpzZ5KjNPEMA",
        "bfb0gAj-FE59arTpFFACl"
      ],
      "frameId": null,
      "index": "b0r",
      "roundness": null,
      "seed": 1022409897,
      "version": 182,
      "versionNonce": 951885577,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775969698449,
      "link": null,
      "locked": false,
      "text": "\n    Rule: Character ⮕ Code Point (Number) ⮕ Encoding (Binary)\n    Java's Choice: UTF-16 (Internal Memory)\n    Web's Choice: UTF-8 (Data Transfer)\n    Key Fact: UTF-8 is \"Variable Length\" (स्मार्ट छ), UTF-16 is \"Fixed-ish\" (जाभाको लागि फास्ट छ)।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n    Rule: Character ⮕ Code Point (Number) ⮕ Encoding (Binary)\n    Java's Choice: UTF-16 (Internal Memory)\n    Web's Choice: UTF-8 (Data Transfer)\n    Key Fact: UTF-8 is \"Variable Length\" (स्मार्ट छ), UTF-16 is \"Fixed-ish\" (जाभाको लागि फास्ट छ)।",
      "autoResize": true,
      "lineHeight": 1.35
    },
