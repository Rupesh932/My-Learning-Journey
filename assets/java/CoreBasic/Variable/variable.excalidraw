      "versionNonce": 1774593287,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775974543745,
      "link": null,
      "locked": false,
      "text": " Boolean.parseBoolean(\"true\") ⮕ स्ट्रिङलाई बुलियनमा बदल्न।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " Boolean.parseBoolean(\"true\") ⮕ स्ट्रिङलाई बुलियनमा बदल्न।",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "Lu6321kkH54cFiAWbUjYo",
      "type": "text",
      "x": 310,
      "y": 4115,
      "width": 820.8659057617188,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "Mv7XDDkLn_yhix5bee4_P",
