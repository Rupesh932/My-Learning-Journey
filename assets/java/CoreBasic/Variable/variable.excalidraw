      "lineHeight": 1.35
    },
    {
      "id": "vQLnGIoT6DHgeU9vaWyCw",
      "type": "text",
      "x": 396,
      "y": 2994.4,
      "width": 686.91357421875,
      "height": 43.2,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
