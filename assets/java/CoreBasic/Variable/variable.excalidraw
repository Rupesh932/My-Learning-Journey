      "seed": 1583845287,
      "version": 107,
      "versionNonce": 1139403815,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775974543745,
      "link": null,
      "locked": false,
      "text": "    Boolean मा एउटा तेस्रो अवस्था पनि हुन सक्छ यदि हामीले र्‍यापर क्लास प्रयोग गर्यौँ भने— null। प्रिमिटिभ boolean मा कहिल्यै null हुँदैन।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    Boolean मा एउटा तेस्रो अवस्था पनि हुन सक्छ यदि हामीले र्‍यापर क्लास प्रयोग गर्यौँ भने— null। प्रिमिटिभ boolean मा कहिल्यै null हुँदैन।",
      "autoResize": true,
      "lineHeight": 1.35
    },
