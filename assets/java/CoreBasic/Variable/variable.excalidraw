      "seed": 974262375,
      "version": 23,
      "versionNonce": 1864638665,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775972002928,
      "link": null,
      "locked": false,
      "text": "जाभामा तिमीले कुनै पनि Unicode क्यारेक्टरलाई त्यसको हेक्साडेसिमल (Hexadecimal) कोड प्रयोग गरेर लेख्न सक्छौ।\n",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "जाभामा तिमीले कुनै पनि Unicode क्यारेक्टरलाई त्यसको हेक्साडेसिमल (Hexadecimal) कोड प्रयोग गरेर लेख्न सक्छौ।\n",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "bJtRgEQGCJQV6effWqMIZ",
      "type": "text",
      "x": 461,
      "y": 3032,
      "width": 412.73687744140625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#fa5252",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1w",
      "roundness": null,
      "seed": 511929513,
      "version": 47,
      "versionNonce": 37820649,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775972043662,
      "link": null,
      "locked": false,
      "text": "char letterA = 'A';\nchar unicodeA = '\\u0041'; // 'A' को युनिकोड\n\nchar nepaliAa = '\\u0905'; // नेपाली 'अ' को युनिकोड\nSystem.out.println(nepaliAa); // Output: अ",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "char letterA = 'A';\nchar unicodeA = '\\u0041'; // 'A' को युनिकोड\n\nchar nepaliAa = '\\u0905'; // नेपाली 'अ' को युनिकोड\nSystem.out.println(nepaliAa); // Output: अ",
      "autoResize": true,
      "lineHeight": 1.25
    },
