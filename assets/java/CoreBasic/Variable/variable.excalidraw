      "seed": 562936713,
      "version": 548,
      "versionNonce": 1354170441,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775969439707,
      "link": null,
      "locked": false,
      "text": "फिचर                                                      ASCII (पुरानो)                                                Unicode / UTF-16 (जाभाको)\n\nबिट (Bits)                                                     ७ वा ८ बिट                                                         १६ बिट (२ बाइट)\n\nदायरा (Range)                                              ० - १२७                                                        ० - ६५,५३५ (Basic Plane मा)\n\nसीमा                                                          केवल अङ्ग्रेजी                                                    संसारका सबै भाषा (नेपाली, इमोजी, आदि)\n\nसम्बन्ध                                                        युनिकोडको जग हो।                                             ASCII लाई आफ्नो भित्र समाहित गरेको छ।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "फिचर                                                      ASCII (पुरानो)                                                Unicode / UTF-16 (जाभाको)\n\nबिट (Bits)                                                     ७ वा ८ बिट                                                         १६ बिट (२ बाइट)\n\nदायरा (Range)                                              ० - १२७                                                        ० - ६५,५३५ (Basic Plane मा)\n\nसीमा                                                          केवल अङ्ग्रेजी                                                    संसारका सबै भाषा (नेपाली, इमोजी, आदि)\n\nसम्बन्ध                                                        युनिकोडको जग हो।                                             ASCII लाई आफ्नो भित्र समाहित गरेको छ।",
      "autoResize": true,
      "lineHeight": 1.35
    },
