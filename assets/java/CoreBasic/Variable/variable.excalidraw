      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "२. Types of Encoding (प्रमुख प्रकारहरू)",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "wWq8kRI6RJwglsMmjwWj2",
      "type": "text",
      "x": 385.5676574707031,
      "y": 2378.3999999999996,
      "width": 316.86468505859375,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "D9NYiUtWfQJTdEivxjXWP"
      ],
      "frameId": null,
      "index": "b1V",
      "roundness": null,
      "seed": 1645347015,
      "version": 126,
      "versionNonce": 481923047,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775971679264,
      "link": null,
      "locked": false,
      "text": "जाभा र वेबको दुनियाँमा यी तीनवटा सबैभन्दा चर्चित छन्:",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "जाभा र वेबको दुनियाँमा यी तीनवटा सबैभन्दा चर्चित छन्:",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "QI7a9wV77Li8mayBowxCJ",
      "type": "text",
      "x": 367.6391906738281,
      "y": 2605.999999999999,
      "width": 799.4103393554688,
      "height": 21.6,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "29zvRR-Zze1ake8Ai7omu",
        "D9NYiUtWfQJTdEivxjXWP"
      ],
      "frameId": null,
      "index": "b1W",
      "roundness": null,
      "seed": 413121287,
      "version": 328,
      "versionNonce": 1592589063,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775971679264,
      "link": null,
      "locked": false,
      "text": "UTF-32                                   जहिले पनि ४ बाइट प्रयोग गर्छ।                   एकदमै सरल तर मेमोरी धेरै खान्छ (Memory Inefficient)।",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UTF-32                                   जहिले पनि ४ बाइट प्रयोग गर्छ।                   एकदमै सरल तर मेमोरी धेरै खान्छ (Memory Inefficient)।",
      "autoResize": true,
      "lineHeight": 1.35
    },
