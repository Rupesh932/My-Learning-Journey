      "versionNonce": 2005628641,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775112211717,
      "link": null,
      "locked": false,
      "text": "Unsigned System (जहाँ सबै Number हरू Positive मात्र हुन्छन्)\n    Lowest Value: 000 (जुन 0 हो)\n    Highest Value: 111 (जुन 7 हो)\n    (यहाँ कुनै Negative नम्बर हुँदैन।)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Unsigned System (जहाँ सबै Number हरू Positive मात्र हुन्छन्)\n    Lowest Value: 000 (जुन 0 हो)\n    Highest Value: 111 (जुन 7 हो)\n    (यहाँ कुनै Negative नम्बर हुँदैन।)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vL526HZPB2MJmxhxy7X_9",
      "type": "text",
      "x": 226,
      "y": 674,
      "width": 676.7855834960938,
      "height": 20,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aa",
      "roundness": null,
      "seed": 920792737,
      "version": 132,
      "versionNonce": 2104591969,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775113109382,
      "link": null,
      "locked": false,
      "text": "0-7(total 8 which is 2^3) and highest value of this unsigned bit is 2^3 - 1( which is 7)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "0-7(total 8 which is 2^3) and highest value of this unsigned bit is 2^3 - 1( which is 7)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8XsKOGKpv_lI5fLqgsops",
      "type": "text",
      "x": 228,
      "y": 697,
      "width": 672.2255859375,
      "height": 20,
      "angle": 0,
      "strokeColor": "#6741d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 1166754575,
      "version": 191,
      "versionNonce": 323549857,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775113102922,
      "link": null,
      "locked": false,
      "text": "4 bit : total 2 ^ 4 = 16(0-15) and highest value can store is 2 ^ 4 - 1 - 15 and so on .",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4 bit : total 2 ^ 4 = 16(0-15) and highest value can store is 2 ^ 4 - 1 - 15 and so on .",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GXw9UZPsp9xm07DGbgf_C",
      "type": "text",
      "x": 150,
      "y": 261,
      "width": 796.7698364257812,
      "height": 40,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
