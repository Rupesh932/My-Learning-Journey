      "roundness": null,
      "seed": 1606648783,
      "version": 100,
      "versionNonce": 1359630080,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775179462534,
      "link": null,
      "locked": false,
      "text": "हामीले प्रयोग गर्ने 1 Byte मा ८-बिट हुन्छन्। त्यसैले त्यसको 'Highest Value' 2 ^ 8 − 1 = 255 हुन्छ। यही कारणले गर्दा तिमीले \nCSS मा रङ (Colors) हरू भर्दा rgb(255, 255, 255) सम्म मात्र भर्न पाउँछौ।",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "हामीले प्रयोग गर्ने 1 Byte मा ८-बिट हुन्छन्। त्यसैले त्यसको 'Highest Value' 2 ^ 8 − 1 = 255 हुन्छ। यही कारणले गर्दा तिमीले \nCSS मा रङ (Colors) हरू भर्दा rgb(255, 255, 255) सम्म मात्र भर्न पाउँछौ।",
      "autoResize": true,
      "lineHeight": 1.25
    },
