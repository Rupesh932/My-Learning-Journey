      "boundElements": [],
      "updated": 1775281598936,
      "link": null,
      "locked": false,
      "text": "in stack, there is no continue place to update 'b' or 0001 to store three byte as a single unit\nnow we need to allocated new memory for this updated value and in future if its size changes\nwe will need to allocated that into proper new location or top of stack. and old address delete\ngarne ho vane all element need to push one step down in stack, which is very expensive interm \nof time .\n",
      "fontSize": 18.54501953125,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "in stack, there is no continue place to update 'b' or 0001 to store three byte as a single unit\nnow we need to allocated new memory for this updated value and in future if its size changes\nwe will need to allocated that into proper new location or top of stack. and old address delete\ngarne ho vane all element need to push one step down in stack, which is very expensive interm \nof time .\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
