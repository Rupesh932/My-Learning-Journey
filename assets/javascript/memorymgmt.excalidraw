      "isDeleted": false,
      "boundElements": [],
      "updated": 1775531925901,
      "link": null,
      "locked": false,
      "text": "१. The Mapping Logic:\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "१. The Mapping Logic:\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "U46-8SJJuKViIT7GTHr-6",
      "type": "text",
      "x": 834.2108411146439,
      "y": 1132.544142823464,
      "width": 656.6829833984375,
      "height": 62.42284978085238,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "cVAIaeNGppCFJyQqUExA-",
        "R6ml28NsZNZI6-EkqoU8D",
        "LLjSiyTEx9mJ5Jvz8Zeg4"
      ],
      "frameId": null,
      "index": "b72",
      "roundness": null,
      "seed": 1416848333,
      "version": 1182,
      "versionNonce": 1595331191,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775531925901,
      "link": null,
      "locked": false,
      "text": "प्रत्येक ब्लक ठ्याक्कै 1-Byte को हुन्छ र प्रत्येकको आफ्नै Address हुन्छ। \nएड्रेस भन्नु नै प्रत्येक ब्लकलाई एउटा नम्बर दिनु हो। अब डाटा स्टोर गर्दा हामीले केवल एउटा काम गर्नुपर्छ— \nभ्यारिएबल a, b लाई उपयुक्त Memory Address सँग 'Map' (जोड्ने) गर्ने।",
      "fontSize": 16.646093274893968,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "प्रत्येक ब्लक ठ्याक्कै 1-Byte को हुन्छ र प्रत्येकको आफ्नै Address हुन्छ। \nएड्रेस भन्नु नै प्रत्येक ब्लकलाई एउटा नम्बर दिनु हो। अब डाटा स्टोर गर्दा हामीले केवल एउटा काम गर्नुपर्छ— \nभ्यारिएबल a, b लाई उपयुक्त Memory Address सँग 'Map' (जोड्ने) गर्ने।",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7puM1yoSdIUwC5Zz2eyiF",
      "type": "text",
      "x": 804.4530912458099,
      "y": 1202.234018028086,
      "width": 366.3396911621094,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "WX5493mj9W5moNtPQnKbx",
        "R6ml28NsZNZI6-EkqoU8D",
        "LLjSiyTEx9mJ5Jvz8Zeg4"
      ],
      "frameId": null,
