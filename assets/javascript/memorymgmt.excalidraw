      "originalText": "समस्या (The Chaos):\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "pd_M2HYnDcPGNHTYb3Z66",
      "type": "text",
      "x": 611.432432395163,
      "y": 711.4221904083909,
      "width": 501.47955322265625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "xD37OCmBzNyCY2zOvtaP8"
      ],
      "frameId": null,
      "index": "b6x",
      "roundness": null,
      "seed": 1235864269,
      "version": 608,
      "versionNonce": 235249635,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775279313025,
      "link": null,
      "locked": false,
      "text": "RAM Organization: The Need for Unique Addressing\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
