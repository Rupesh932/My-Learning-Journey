    {
      "id": "bEEwlrGO3-7W0jKlkI3vf",
      "type": "text",
      "x": 581.4541777978163,
      "y": 761.1841421194745,
      "width": 692.4009119260257,
      "height": 204.5708207812999,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "xD37OCmBzNyCY2zOvtaP8"
      ],
      "frameId": null,
      "index": "b6u",
      "roundness": null,
      "seed": 1739522093,
      "version": 1155,
      "versionNonce": 1286213381,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775359696589,
      "link": null,
      "locked": false,
      "text": "\n\nयदि हामीले RAM मा डाटा राख्दा कुन भ्यारिएबलले कुन लोकेसन प्रयोग गरिरहेको छ भन्ने कुरा प्रस्ट पारेनौँ भने, \nडाटाको आकार बढ्दै जाँदा सबै कुरा 'Messy' (अस्तव्यस्त) हुन्छ। एउटा डाटा खोज्न जाँदा अर्को भेटिने डर हुन्छ।\n\n\nयही अलमल हटाउन इन्जिनियरहरूले 'Byte-Addressable Memory' को अवधारणा विकास गरे:\n    Unique Identity: प्रत्येक मेमोरी लोकेसनलाई एउटा छुट्टै र 'Unique' पहिचान दिनु नै यसको मुख्य उद्देश्य हो।\n    Byte Blocks: मेमोरीलाई साना-साना ब्लकहरूमा विभाजित गरियो, जहाँ प्रत्येक ब्लक 1 Byte (8-bit) को हुन्छ।\n    Memory Address: प्रत्येक १-बाइटको ब्लकलाई एउटा Unique Memory Address दिइयो। यसले गर्दा CPU लाई \n    कुन डाटा ठ्याक्कै कहाँ छ भनेर थाहा पाउन 'GPS' ले जस्तै मद्दत गर्छ।",
      "fontSize": 14.877877875003628,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\nयदि हामीले RAM मा डाटा राख्दा कुन भ्यारिएबलले कुन लोकेसन प्रयोग गरिरहेको छ भन्ने कुरा प्रस्ट पारेनौँ भने, \nडाटाको आकार बढ्दै जाँदा सबै कुरा 'Messy' (अस्तव्यस्त) हुन्छ। एउटा डाटा खोज्न जाँदा अर्को भेटिने डर हुन्छ।\n\n\nयही अलमल हटाउन इन्जिनियरहरूले 'Byte-Addressable Memory' को अवधारणा विकास गरे:\n    Unique Identity: प्रत्येक मेमोरी लोकेसनलाई एउटा छुट्टै र 'Unique' पहिचान दिनु नै यसको मुख्य उद्देश्य हो।\n    Byte Blocks: मेमोरीलाई साना-साना ब्लकहरूमा विभाजित गरियो, जहाँ प्रत्येक ब्लक 1 Byte (8-bit) को हुन्छ।\n    Memory Address: प्रत्येक १-बाइटको ब्लकलाई एउटा Unique Memory Address दिइयो। यसले गर्दा CPU लाई \n    कुन डाटा ठ्याक्कै कहाँ छ भनेर थाहा पाउन 'GPS' ले जस्तै मद्दत गर्छ।",
      "autoResize": false,
      "lineHeight": 1.25
    },
