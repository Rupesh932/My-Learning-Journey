      "isDeleted": false,
      "boundElements": null,
      "updated": 1775016212244,
      "link": null,
      "locked": false,
      "text": "and can remember means push outer var to heap while \ndeleting outer stack from memory is called closure",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "and can remember means push outer var to heap while \ndeleting outer stack from memory is called closure",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "g14q-wUB1AUQgwuW57Lev",
      "type": "text",
      "x": 257,
      "y": 1030.5,
      "width": 98.89988708496094,
