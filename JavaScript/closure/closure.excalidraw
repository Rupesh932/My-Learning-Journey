      "versionNonce": 128610956,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775016212244,
      "link": null,
      "locked": false,
      "text": "while increment pointing to object\nor function its sees increment is \nusing count so it(engine) feels \ni need to store this count to\nfurther use and copy the reference\nof count in heap which is using\nby increment's count",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "while increment pointing to object\nor function its sees increment is \nusing count so it(engine) feels \ni need to store this count to\nfurther use and copy the reference\nof count in heap which is using\nby increment's count",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "97ZomkLkyYpjCaCJbajHb",
      "type": "text",
      "x": 12,
      "y": 988,
      "width": 422.68878173828125,
      "height": 40,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
