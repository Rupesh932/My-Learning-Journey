      "updated": 1774766868840,
      "link": null,
      "locked": false,
      "text": "pick any element : 6 -> sorted left , unsorted right\n                      8 -> same\n                      10 -> same\n                       1  -> unsorted left, sorted right\n                       2 -> unsorted left, right must sorted",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "pick any element : 6 -> sorted left , unsorted right\n                      8 -> same\n                      10 -> same\n                       1  -> unsorted left, sorted right\n                       2 -> unsorted left, right must sorted",
      "autoResize": true,
      "lineHeight": 1.25
