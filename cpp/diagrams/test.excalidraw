    {
      "id": "bKshs9DMpjdldIVZwyhoy",
      "type": "text",
      "x": -569,
      "y": 1219.5282228466301,
      "width": 945.6018676757812,
      "height": 40,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Q",
      "roundness": null,
      "seed": 1099375984,
      "version": 402,
      "versionNonce": 483858288,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774918764181,
      "link": null,
      "locked": false,
      "text": "rotated 4: mid = 8 (let)  => 4 < 8 = true  i.e. left sorted , so you can find target in right side.\nrotated 4: mid = 2(let) => 4 < 2 = false i.e. right side of 2 must be sorted  so target(small) might be mid or in left side.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "rotated 4: mid = 8 (let)  => 4 < 8 = true  i.e. left sorted , so you can find target in right side.\nrotated 4: mid = 2(let) => 4 < 2 = false i.e. right side of 2 must be sorted  so target(small) might be mid or in left side.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dMakerBTLlqsrEVD2l9d6",
      "type": "text",
      "x": -484,
      "y": 1403.5282228466301,
      "width": 218.45639038085938,
      "height": 320,
      "angle": 0,
      "strokeColor": "#099268",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1R",
      "roundness": null,
      "seed": 470549360,
      "version": 479,
      "versionNonce": 1072364400,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774926984606,
      "link": null,
      "locked": false,
      "text": "start = 0;\nend = array.length -1\nwhile(start < end)\n{\nmid = 0 + (5 - 0 ) / 2 = 8\nif( array[0] < array[mid]) \n  { \n       start = mid + 1\n  }\nelse{\n        end = mid\n   } \n}\nreturn array[end]\n \n        ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "start = 0;\nend = array.length -1\nwhile(start < end)\n{\nmid = 0 + (5 - 0 ) / 2 = 8\nif( array[0] < array[mid]) \n  { \n       start = mid + 1\n  }\nelse{\n        end = mid\n   } \n}\nreturn array[end]\n \n        ",
      "autoResize": false,
      "lineHeight": 1.25
    },
