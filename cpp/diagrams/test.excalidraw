    {
      "id": "yMRfS01G9LKe3Xm8qLafo",
      "type": "text",
      "x": 23.742296218872042,
      "y": 777.1410082747051,
      "width": 483.87298583984375,
      "height": 60,
      "angle": 0,
      "strokeColor": "#7950f2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ax",
      "roundness": null,
      "seed": 843574284,
      "version": 360,
      "versionNonce": 447196560,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774923369446,
      "link": null,
      "locked": false,
      "text": "compare array[end] with mid \n    mid = start + (end - start) / 2 = 0 + (6 - 0) / 2 = 3 ie 10\n    array[0] < array[mid] => 4 < 10 = true i.e. left sorted",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "compare array[end] with mid \n    mid = start + (end - start) / 2 = 0 + (6 - 0) / 2 = 3 ie 10\n    array[0] < array[mid] => 4 < 10 = true i.e. left sorted",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "My4xmVQrf7GMOwI3gQo63",
      "type": "text",
      "x": 44.669677734375,
      "y": 847.25,
      "width": 429.53680419921875,
      "height": 40,
      "angle": 0,
      "strokeColor": "#12b886",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b00",
      "roundness": null,
      "seed": 1158536460,
      "version": 129,
      "versionNonce": 1692370188,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774766747912,
      "link": null,
      "locked": false,
      "text": "if mid = 4\n array[0] < array[mid] => 4 < 1 = false i.e. right sorted",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if mid = 4\n array[0] < array[mid] => 4 < 1 = false i.e. right sorted",
      "autoResize": true,
      "lineHeight": 1.25
    },
