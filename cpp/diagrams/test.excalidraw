    {
      "id": "tckR0E7So3Xn-W4hKkN2Q",
      "type": "text",
      "x": -278.14285714285813,
      "y": 1510.6710799894872,
      "width": 428.38482666015625,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "seed": 399475568,
      "version": 341,
      "versionNonce": 1963369328,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774924233998,
      "link": null,
      "locked": false,
      "text": "if(array[0] < array[mid]) वाला लोजिकमा एउटा सानो 'Risk' छ।\nयदि एरे पहिले नै Sorted छ (जस्तै [2, 4, 6, 8, 10]) भने,\narray[0] < array[mid] सधैं true हुन्छ र तिम्रो start \nअगाडि बढ्दै जान्छ, जसले गर्दा तिमीले सही मिनिमम (२) गुमाउन \nसक्छौ।\nसही लोजिक: बाइनरी सर्चमा रोटेटेड एरेको 'Minimum' खोज्दा \nसधैं array[mid] लाई array[end] सँग तुलना गर्नु सबैभन्दा\nसुरक्षित र 'Optimized' हुन्छ।array[0] < array[mid] को \nतुलनाले सधैं सही बाटो देखाउँदैन। \n   if(array[mid] > array[end]) start = min + 1\n    else end = mid\n   return array(start)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if(array[0] < array[mid]) वाला लोजिकमा एउटा सानो 'Risk' छ।\nयदि एरे पहिले नै Sorted छ (जस्तै [2, 4, 6, 8, 10]) भने,\narray[0] < array[mid] सधैं true हुन्छ र तिम्रो start \nअगाडि बढ्दै जान्छ, जसले गर्दा तिमीले सही मिनिमम (२) गुमाउन \nसक्छौ।\nसही लोजिक: बाइनरी सर्चमा रोटेटेड एरेको 'Minimum' खोज्दा \nसधैं array[mid] लाई array[end] सँग तुलना गर्नु सबैभन्दा\nसुरक्षित र 'Optimized' हुन्छ।array[0] < array[mid] को \nतुलनाले सधैं सही बाटो देखाउँदैन। \n   if(array[mid] > array[end]) start = min + 1\n    else end = mid\n   return array(start)",
      "autoResize": true,
      "lineHeight": 1.25
    },
