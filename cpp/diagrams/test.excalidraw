    {
      "id": "8xtz9UONwDHL9iCK6nnYi",
      "type": "text",
      "x": -559.1428571428581,
      "y": 2205.171079989487,
      "width": 505.2969970703125,
      "height": 280,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b27",
      "roundness": null,
      "seed": 1323012464,
      "version": 77,
      "versionNonce": 1115656048,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774931830497,
      "link": null,
      "locked": false,
      "text": "2. array[mid] लाई array[start] सँग तुलना गर्नुपर्छ:\n    If array[start] <= array[mid]:\n    यसको मतलब बायाँ भाग (Left side) पूर्ण रूपमा Sorted छ।\n        अब तिमीले चेक गर्छौ: के target यो रेन्ज (start देखि mid) भित्र पर्छ?\n        Sorted भागमा 'Target' छ कि छैन भन्नलाई सधैं 'Double Boundary'\n        (Start <= Target <= End) चेक गर्नुपर्छ।\n\n        यदि पर्छ भने, end = mid - 1 गर।\n        पर्दैन भने, अर्को तिर (start = mid + 1) खोज।\n    Else (array[mid] < array[end]):\n    यसको मतलब दायाँ भाग (Right side) पूर्ण रूपमा Sorted छ।\n        अब तिमीले चेक गर्छौ: के target यो रेन्ज (mid देखि end) भित्र पर्छ?\n        यदि पर्छ भने, start = mid + 1 गर।\n        पर्दैन भने, अर्को तिर (end = mid - 1) खोज।",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. array[mid] लाई array[start] सँग तुलना गर्नुपर्छ:\n    If array[start] <= array[mid]:\n    यसको मतलब बायाँ भाग (Left side) पूर्ण रूपमा Sorted छ।\n        अब तिमीले चेक गर्छौ: के target यो रेन्ज (start देखि mid) भित्र पर्छ?\n        Sorted भागमा 'Target' छ कि छैन भन्नलाई सधैं 'Double Boundary'\n        (Start <= Target <= End) चेक गर्नुपर्छ।\n\n        यदि पर्छ भने, end = mid - 1 गर।\n        पर्दैन भने, अर्को तिर (start = mid + 1) खोज।\n    Else (array[mid] < array[end]):\n    यसको मतलब दायाँ भाग (Right side) पूर्ण रूपमा Sorted छ।\n        अब तिमीले चेक गर्छौ: के target यो रेन्ज (mid देखि end) भित्र पर्छ?\n        यदि पर्छ भने, start = mid + 1 गर।\n        पर्दैन भने, अर्को तिर (end = mid - 1) खोज।",
      "autoResize": true,
      "lineHeight": 1.25
    },
